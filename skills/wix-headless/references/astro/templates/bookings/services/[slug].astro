---
// src/pages/services/[slug].astro — SSR service detail + client-side booking flow.
// Two dirs deep inside src/ → import with ../../ (not three ../).
import Layout from "../../layouts/Layout.astro";
import SeoTags from "../../components/SeoTags.astro";
import ServiceBookingFlow from "../../components/ServiceBookingFlow";
import CourseEnrollFlow from "../../components/CourseEnrollFlow";
import { services } from "@wix/bookings";
import { events as calendarEvents } from "@wix/calendar";
import { forms } from "@wix/forms";
import { auth } from "@wix/essentials";

const BOOKING_APP_ID = "13d21c63-b5ec-5912-8397-c3a5ddb27a97";
const { slug } = Astro.params;

// Carried from the catalog's location selector (when the site has >1 location):
// the default location the availability picker scopes to. Absent on single-location
// sites (and on deep links — the picker then defaults to the service's first location).
const reqUrl = new URL(Astro.request.url);
const locationId = reqUrl.searchParams.get("locationId") ?? undefined;

let service: any = null;
try {
  // Ambient SSR via @wix/essentials. Single service by slug: the .eq() builder
  // chain on mainSlug.name + appId (the form the @wix/bookings SDK expects).
  const result = await auth
    .elevate(services.queryServices)({ conditionalFields: ["STAFF_MEMBER_DETAILS"] })
    .eq("mainSlug.name", slug)
    .eq("appId", BOOKING_APP_ID)
    .limit(1)
    .find();
  service = result.items?.[0] ?? null;
} catch (err) {
  console.error(`[services/${slug}] detail query failed:`, err);
}

if (!service) return Astro.redirect("/services", 302);

// Extract plain text from a label that may be a string or Ricos RichContent object.
function labelText(label: any): string {
  if (!label) return "";
  if (typeof label === "string") return label;
  const out: string[] = [];
  const walk = (n: any) => {
    if (!n) return;
    if (n.textData?.text) out.push(n.textData.text);
    (n.nodes ?? []).forEach(walk);
  };
  (label.nodes ?? []).forEach(walk);
  return out.join(" ").trim();
}

// Normalize one @wix/forms field into a render descriptor for the island.
// READ `form.formFields` — the documented field array (the `inputOptions` shape).
// (`form.fields` is an internal runtime field; do not use it.) Each field's
// `validation` sub-key (string/number/boolean/array/predefined) determines the
// SUBMISSION VALUE TYPE createBooking expects; a wrong type rejects the whole
// booking. Returns null for non-input / hidden fields.
function normalizeFormField(f: any): any {
  // Coerce the `formFields` (inputOptions) shape into the intermediate the
  // render-type derivation below works on.
  if (f.inputOptions) {
    const io = f.inputOptions;
    const to = io.stringOptions || io.numberOptions || io.booleanOptions || io.arrayOptions || io.addressOptions || io.wixFileOptions || {};
    const optsBlock = to.dropdownOptions || to.radioGroupOptions || to.checkboxGroupOptions || to.tagsOptions;
    const label = (to.textInputOptions || to.dropdownOptions || to.phoneInputOptions || to.numberInputOptions || to.multilineAddressOptions || optsBlock || {}).label;
    const validation =
      io.stringOptions ? { string: to.validation ?? {}, required: io.required }
      : io.numberOptions ? { number: to.validation ?? {}, required: io.required }
      : io.booleanOptions ? { boolean: to.validation ?? {}, required: io.required }
      : io.arrayOptions ? { array: to.validation ?? {}, required: io.required }
      : io.addressOptions ? { predefined: { format: "MULTILINE_ADDRESS", multilineAddressOptions: to.validation }, required: io.required }
      : io.wixFileOptions ? { predefined: { format: "WIX_FILE" }, required: io.required }
      : { required: io.required };
    f = { id: f.id ?? f._id, hidden: f.hidden, identifier: f.identifier, target: io.target,
          validation, view: { label, options: optsBlock?.options, componentType: to.componentType, fieldType: f.identifier } };
  }

  const target = f.target;
  if (!target || f.hidden) return null; // DISPLAY header / hidden → not collected
  const v = f.validation ?? {};
  const view = f.view ?? {};
  const ct = view.componentType; // from the coerced inputOptions shape (componentType)
  const required = !!v.required;
  const label = labelText(view.label) || target;
  const options = (view.options ?? []).map((o: any) => ({
    value: o.value ?? o.label ?? "",
    label: o.label ?? o.value ?? "",
  }));

  let renderType = "text";
  let valueType = "string";
  if (v.string) {
    const fmt = v.string.format;
    if (ct === "RADIO_GROUP") renderType = "radio";
    else if (ct === "DROPDOWN" || ct === "SERVICES_DROPDOWN") renderType = "dropdown";
    else if (ct === "DATE_PICKER" || ct === "DATE_INPUT" || fmt === "DATE") renderType = "date";
    else if (ct === "DATE_TIME" || fmt === "DATE_TIME") renderType = "datetime";
    else if (ct === "TIME_INPUT" || fmt === "TIME") renderType = "time";
    else if (ct === "PHONE_INPUT" || fmt === "PHONE" || view.fieldType === "BOOKINGS_PHONE" || target === "phone") renderType = "tel";
    else if (options.length) renderType = "dropdown"; // radio also submits a string; dropdown is safe
    else if (f.identifier === "TEXT_AREA" || view.fieldType === "TEXT_AREA") renderType = "textarea";
    else if (fmt === "EMAIL" || target === "email") renderType = "email";
    else renderType = "text";
  } else if (v.number) {
    valueType = "number"; renderType = "number";
  } else if (v.array) {
    valueType = "array"; renderType = "checkbox_group";
  } else if (v.predefined?.format === "MULTILINE_ADDRESS") {
    valueType = "address"; renderType = "address";
  } else if (v.predefined?.format === "WIX_FILE") {
    valueType = "file"; renderType = "file";
  } else {
    valueType = "boolean"; renderType = "checkbox"; // checkbox: validation type often absent
  }

  const out: any = { id: f.id ?? f._id, target, label, required, renderType, valueType };
  if (options.length) out.options = options;
  if (view.addOther) out.addOther = true;
  if (renderType === "address") {
    out.addressFields = v.predefined?.multilineAddressOptions?.fields ?? {};
    out.allowedCountries = v.predefined?.multilineAddressOptions?.allowedCountries ?? [];
  }
  if (renderType === "file") out.fileLimit = view.valueSliderLimit ?? 1;
  const fmt = v.string?.format;
  out.validation = {
    minLength: v.string?.minLength, maxLength: v.string?.maxLength, pattern: v.string?.pattern,
    format: fmt && fmt !== "UNDEFINED" ? fmt : undefined,
    enum: v.string?.enum?.length ? v.string.enum : undefined,
    minimum: v.number?.minimum, maximum: v.number?.maximum, multipleOf: v.number?.multipleOf,
    minItems: v.array?.minItems, maxItems: v.array?.maxItems,
  };
  return out;
}

// Booking-form SCHEMA — the form belongs to the service (service.form._id) in the
// bookings namespace. Read it server-side and pass the normalized field list to the
// island, which renders each field by type and collects the correctly-typed value.
let formFields: any[] = [];
try {
  const formId = service.form?._id;
  if (formId) {
    const res: any = await auth.elevate(forms.getForm)(formId);
    const form = res?.form ?? res;
    const raw: any[] = form?.formFields ?? [];
    formFields = raw.map(normalizeFormField).filter(Boolean);
    // Order fields by the form's LAYOUT grid (steps[].layout.large.items: row, column),
    // NOT the fields[] array order — this is the order the merchant configured.
    const layoutItems = (form?.steps ?? []).flatMap((s: any) => s?.layout?.large?.items ?? []);
    const pos = new Map<string, { row: number; col: number }>(
      layoutItems.map((it: any, i: number) => [it.fieldId, { row: it.row ?? i, col: it.column ?? 0 }]),
    );
    formFields.sort((a: any, b: any) => {
      const pa = pos.get(a.id) ?? { row: 1e9, col: 0 };
      const pb = pos.get(b.id) ?? { row: 1e9, col: 0 };
      return pa.row - pb.row || pa.col - pb.col;
    });
  }
} catch (err) {
  console.error(`[services/${slug}] booking form schema failed:`, err);
}

const formatPrice = (p: any): string | undefined => {
  if (!p) return undefined;
  if (p.rateType === "NO_FEE") return "Free";
  if (p.rateType === "FIXED" && p.fixed?.price) {
    const { value, currency } = p.fixed.price;
    if (!value) return undefined;
    return new Intl.NumberFormat("en-US", { style: "currency", currency: currency ?? "USD" }).format(Number(value));
  }
  return undefined;
};
const price = formatPrice(service.payment);
const duration = service.schedule?.availabilityConstraints?.sessionDurations?.[0] ?? 60;
const imageUrl = service.media?.mainMedia?.image?.url ?? service.media?.items?.[0]?.image?.url;
const serviceName = service.name ?? "Service";
const seoTags = service.seoData?.tags ?? [];
const serviceType = service.type ?? "APPOINTMENT";
const isCourse = serviceType === "COURSE";
const bookHeading = isCourse ? "Enroll in this course" : "Book this service";

// ── COURSE details (appointments/classes skip all of this) ───────────────────
// A course is enrolled as a whole SERIES (no per-slot calendar): the detail page
// shows the schedule + capacity + an Enroll action. Start/end live on the service
// schedule (visitor-readable); the per-session list, capacity, staff, and location
// all come from ONE Calendar Events V3 query (`events.queryEvents` by scheduleId) —
// exactly how the native Wix course page does it. `listEventTimeSlots` returns
// NOTHING for a COURSE (it's class-only), so this is the path. Capacity comes
// straight off the events' remainingCapacity/totalCapacity (the native page does NOT
// use Query Extended Bookings for it). Elevated here on astro SSR; an own/static build
// can call queryEvents as a visitor (the native public page does — see WIRING.md).
// Normalize schedule dates to ISO strings: the SDK can deserialize these to Date
// OBJECTS (same as the event dates below). A raw Date flows into the confirmation
// `startDate` query param as a locale-dependent Date.toString(), which the
// confirmation page can't reliably parse — keep them ISO strings everywhere.
const toIso = (d: any): string | undefined => (d ? new Date(d).toISOString() : undefined);
const firstSessionStart = toIso(service.schedule?.firstSessionStart);
const lastSessionEnd = toIso(service.schedule?.lastSessionEnd);
const bookAfterStart = !!service.bookingPolicy?.bookAfterStartPolicy?.enabled;
const STAFF_RESOURCE_TYPE_ID = "1cd44cf8-756f-41c3-bd90-3e2ffcaf1155";
let courseCapacity: any = null;
let courseSessions: { start: string; end?: string; durationMin?: number; staff?: string }[] = [];
let courseSessionCount = 0;
let courseLocation: string | undefined;
if (isCourse && service.schedule?._id) {
  try {
    const nowIso = new Date().toISOString();
    const res: any = await auth.elevate(calendarEvents.queryEvents)({
      filter: { scheduleId: service.schedule._id },
      cursorPaging: { limit: 100 },
    });
    // (event start/end .utcDate are also Date OBJECTS from the SDK — the shared toIso
    // above normalizes them, or the upcoming-filter would silently drop every session.)
    const staffName = (e: any): string | undefined =>
      ((e.resources ?? []).filter((r: any) => r.type === STAFF_RESOURCE_TYPE_ID).map((r: any) => r.name).filter(Boolean).join(", ")) || undefined;
    const locationLabel = (loc: any): string | undefined =>
      !loc ? undefined : loc.name || (loc.type === "CUSTOM" ? "Custom location" : loc.type === "CUSTOMER" ? "Your location" : "In person");

    const events = (res?.events ?? []).filter((e: any) => e.status !== "CANCELLED");
    const cap = events[0]; // each session carries the course-level total/remaining
    if (cap) {
      const totalCapacity = cap.totalCapacity ?? service.defaultCapacity ?? 0;
      const remaining = cap.remainingCapacity ?? totalCapacity;
      courseCapacity = { totalCapacity, remaining, isFull: totalCapacity > 0 && remaining <= 0 };
    }
    courseLocation = locationLabel(cap?.location);
    const upcoming = events
      .map((e: any) => {
        const start = toIso(e.start?.utcDate ?? e.start?.localDate);
        const end = toIso(e.end?.utcDate ?? e.end?.localDate);
        const durationMin = start && end ? Math.round((Date.parse(end) - Date.parse(start)) / 60000) : undefined;
        return { start, end, durationMin, staff: staffName(e) };
      })
      .filter((e: any) => e.start && (e.end ?? e.start) >= nowIso) // upcoming only
      .sort((a: any, b: any) => a.start!.localeCompare(b.start!));
    courseSessionCount = upcoming.length; // true total
    courseSessions = upcoming; // all upcoming (bounded by the 100-event query); the island paginates
  } catch (err) {
    console.error(`[services/${slug}] course details query failed:`, err);
  }
}

// Staff for the optional staff picker — carried on the service via the
// STAFF_MEMBER_DETAILS conditional field (already requested in the query above).
// Each entry is { staffMemberId, name } — `staffMemberId` is, despite the name,
// the resource id (the calendar filters availability + books by it). The calendar
// shows the picker only when there is more than one; empty/absent → "any staff
// member" (the ANY_RESOURCE fallback).
const staffMembers = service.staffMemberDetails?.staffMembers ?? [];

// Business locations the service is offered at — sourced from `queryLocations()`
// (the site's real business locations, whose ids the availability engine
// recognizes), intersected with the service's own location ids. Availability is
// scoped to one of these so a multi-location service doesn't return duplicate
// per-location time slots (listAvailabilityTimeSlots returns one slot per location
// otherwise). Source from `queryLocations()`, NOT from `service.locations` alone:
// a service's location entry can carry an id the availability engine doesn't
// recognize, and scoping to it returns zero slots. When the site has no business
// locations this resolves to [] and the calendar fetches unscoped.
let serviceLocations: { _id: string; name?: string }[] = [];
try {
  const locResult: any = await auth.elevate(services.queryLocations)();
  const businessLocations = locResult?.businessLocations?.locations ?? [];
  const serviceLocationIds = new Set(
    (service.locations ?? [])
      .filter((l: any) => (l.type ?? "BUSINESS") === "BUSINESS")
      .map((l: any) => l.business?._id ?? l._id)
      .filter(Boolean),
  );
  serviceLocations = businessLocations
    .filter((l: any) => serviceLocationIds.has(l._id))
    .map((l: any) => ({ _id: l._id, name: l.business?.name ?? "Location" }));
} catch (err) {
  console.error(`[services/${slug}] queryLocations failed:`, err);
}
---

<!--
  Width: use `container-reading` (max-width: var(--container-prose) + auto margins)
  for a deliberate prose measure. Bare `max-w-<size>` keys resolve to Tailwind's
  --container-* scale, which is wider than ideal for reading text.
-->
<Layout title={serviceName} description={service.tagLine ?? service.description}>
  <SeoTags tags={seoTags} slot="head" />
  <section class="container-reading px-6 py-24">
    <a href="/services" class="inline-block text-sm text-mute hover:text-ink mb-8">← All services</a>

    <!-- Optional banner image — only when the service has media (image-less is the
         common seed case; rendering a fixed placeholder collapses the layout). -->
    {imageUrl && (
      <img src={imageUrl} alt={serviceName} class="w-full h-64 object-cover rounded-lg mb-8" />
    )}

    <div class="flex flex-col gap-4 mb-16">
      <hr class="editorial-rule w-16 ml-0" />
      <h1 class="font-display text-4xl md:text-5xl leading-tight">{serviceName}</h1>
      {service.tagLine && <p class="text-lg text-mute leading-relaxed max-w-prose">{service.tagLine}</p>}
      <div class="flex items-center gap-4 text-sm text-mute">
        {isCourse
          ? firstSessionStart && (
              <span>
                {new Date(firstSessionStart).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                {lastSessionEnd && ` – ${new Date(lastSessionEnd).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}`}
              </span>
            )
          : <span>{duration} min</span>}
        {price && <span class="text-ink font-medium">{price}</span>}
      </div>
      {service.description && <p class="text-ink leading-relaxed max-w-prose">{service.description}</p>}
    </div>

    <section class="border-t border-rule pt-12">
      <h2 class="font-display text-3xl leading-tight mb-8">{bookHeading}</h2>
      {isCourse ? (
        <CourseEnrollFlow
          service={service}
          serviceName={serviceName}
          fields={formFields}
          scheduleId={service.schedule?._id}
          firstSessionStart={firstSessionStart}
          lastSessionEnd={lastSessionEnd}
          capacity={courseCapacity}
          sessions={courseSessions}
          sessionCount={courseSessionCount}
          location={courseLocation}
          bookAfterStart={bookAfterStart}
          client:only="react"
        />
      ) : (
        <ServiceBookingFlow
          service={service}
          serviceName={serviceName}
          serviceType={serviceType}
          fields={formFields}
          staffMembers={staffMembers}
          locations={serviceLocations}
          locationId={locationId}
          client:only="react"
        />
      )}
    </section>
  </section>
</Layout>
