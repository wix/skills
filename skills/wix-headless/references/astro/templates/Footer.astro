---
// ── Composer skeleton: src/components/Footer.astro ────────────────────────────
// Substitutions (see compose.mjs):
//   {{brand.name}} — brand name for the wordmark + copyright.
//   {{shell.footerTagline}} — short brand-voice tagline from data.shell.
//   {{nav.links}} — same inlined Navigation links array (mirror/subset);
//        one <a href={href}>{label}</a> per entry, labels VERBATIM. No cart,
//        login, or account links.
// Fixed bulk (keep literal): transition:persist, the year expression.
const year = new Date().getFullYear();
---
<footer class="site-footer" transition:persist="site-footer">
  <div class="max-w-6xl mx-auto px-6 py-16 flex flex-col md:flex-row md:items-start md:justify-between gap-8">
    <div class="flex flex-col gap-3 max-w-prose">
      <span class="font-display text-lg text-ink">{{brand.name}}</span>
      <p class="text-sm">{{shell.footerTagline}}</p>
    </div>
    <nav>
      <ul class="flex flex-col gap-3 text-sm">
        {{nav.links}}
      </ul>
    </nav>
  </div>
  <div class="max-w-6xl mx-auto px-6 pb-8 text-xs">
    <p>© {year} {{brand.name}}. All rights reserved.</p>
  </div>
</footer>
