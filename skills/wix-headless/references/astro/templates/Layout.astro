---
// ── Composer skeleton: src/layouts/Layout.astro ──────────────────────────────
// Fully replaces the scaffold's bare stub. The universal progress-bar <script>
// and the View Transitions wiring are LITERAL fixed bulk — do not re-author.
// That script is PLAIN JS on purpose (inline <script> bodies are dep-scanned by
// esbuild, which is not TS-aware — no generics / `as` / param type annotations).
// Composer's only substitutions (compose.mjs):
//   {{components-css-imports}} — one `import '../styles/components-<pack>.css';`
//        per pack in "Packs with components" (omit entirely when none).
//   {{fonts.googleHref}} — the Google Fonts <link> href built from designTokens
//        .fonts (display + body families). Omit the <link> if fonts are system.
//   {{brand.name}} — default <title>.
//   {{stores-nav-script}} — the category-rail / rail-anchor <script>, emitted by
//        compose.mjs ONLY when the `stores` pack is loaded; the placeholder line
//        is removed otherwise. It is pack-specific client JS — shipping it on a
//        non-stores site is dead code that targets routes/selectors absent there.
import '../styles/global.css';
{{components-css-imports}}
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  hasSeoTags?: boolean;
}
const { title, description, hasSeoTags = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg'/%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="{{fonts.googleHref}}" />
    {!hasSeoTags && (
      <>
        <title>{title ? `${title} · {{brand.name}}` : "{{brand.name}}"}</title>
        {description && <meta name="description" content={description} />}
      </>
    )}
    <slot name="head" />
    <ClientRouter />
  </head>
  <body>
    <div class="nav-progress" data-nav-progress aria-hidden="true"></div>
    <Navigation />
    <main><slot /></main>
    <Footer />
    <script>
      // Universal top loading bar across View Transitions. Pack-agnostic — ships
      // on every site. PLAIN JS ONLY: an inline <script> is parsed by esbuild's
      // dependency scanner, which is NOT TypeScript-aware — generics
      // (querySelector<T>), `as` casts, and param type annotations ((e: any))
      // make the dep-scan throw `Expected ";"` and fail the whole build. Keep
      // this body free of TS-only syntax.
      var progress = document.querySelector("[data-nav-progress]");
      function startProgress() {
        if (!progress) return;
        progress.dataset.state = "loading";
        document.body.dataset.navigating = "true";
      }
      function endProgress() {
        if (!progress) return;
        progress.dataset.state = "done";
        delete document.body.dataset.navigating;
        window.setTimeout(function () {
          if (progress.dataset.state === "done") delete progress.dataset.state;
        }, 320);
      }
      document.addEventListener("astro:before-preparation", startProgress);
      document.addEventListener("astro:after-swap", endProgress);
      document.addEventListener("astro:page-load", endProgress);
    </script>
    {{stores-nav-script}}
  </body>
</html>
